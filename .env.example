# Copy to ".env" in this folder (tallerProxy) and edit. Used by scripts/run-jar-with-env.ps1
# so the backend picks up CORS without editing application.properties.

# Comma-separated list of frontend origins (browser URL where the UI is served).
# Examples: Next.js default port 3000, Vite 5173, etc.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: same values can be set in your shell before "java -jar" (no .env file needed):
#   setx APP_CORS_ALLOWED_ORIGINS "http://localhost:5173"
# Or in PowerShell for current session only:
#   $env:APP_CORS_ALLOWED_ORIGINS = "http://localhost:5173"
